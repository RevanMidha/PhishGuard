# ============================================================
# PhishGuard — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
# ============================================================

# ---------------------------
# Node.js Backend
# ---------------------------
PORT=5000                                        # Port the Express server listens on
MONGO_URI=mongodb://mongo:27017/phishguard       # MongoDB connection string (Docker default)
JWT_SECRET=your_jwt_secret_here                  # Secret key for signing JWT tokens

# ---------------------------
# ML Engine
# ---------------------------
ML_ENGINE_URL=http://ml_engine:5001              # Internal URL for the Python Flask ML service
                                                 # Use http://localhost:5001 for local (non-Docker) dev

# ---------------------------
# Client (Frontend)
# ---------------------------
VITE_API_URL=http://localhost:5000               # Backend API base URL used by the React frontend
